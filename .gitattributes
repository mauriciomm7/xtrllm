# Enforce LF endings for source and text files
*.py     text eol=lf
*.ipynb  text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.env    text eol=lf
*.sh     text eol=lf
*.bash   text eol=lf
Makefile text eol=lf
*.gitignore     text eol=lf
*.gitattributes text eol=lf
.editorconfig   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.pdf    binary
*.zip    binary

